def ask_chain(question):
    print(f"\n{'='*60}")
    print(f"QUESTION: {question}")
    print(f"{'='*60}")

    result = medimind_chain.invoke({"question": question})

    answer = result["answer"]
    if result.get("source_documents"):
        sources = list(set(
            doc.metadata["source"]
            for doc in result["source_documents"]
        ))
        answer += f"\n\nSources: {', '.join(sources)}"

    print(f"MEDIMIND: {answer}")
    return result

