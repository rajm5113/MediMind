# ============================================================
# PHASE 3 CELL 3: Chunk, embed, and build FAISS index
# ============================================================
import numpy as np
import faiss
import json
from sentence_transformers import SentenceTransformer

# ------------------------------------------------------------
# PART A: Chunk the documents
# ------------------------------------------------------------
# Why chunking?
# Each document is ~1000-1300 chars.
# When a user asks "what is the HbA1c target for diabetes?"
# we don't want to retrieve the ENTIRE diabetes document.
# We want just the relevant sentence or paragraph.
# Chunking splits documents into smaller pieces so retrieval
# is precise. Same thing Claude does when you upload a PDF.

def chunk_document(text, source, chunk_size=400, overlap=50):
    """
    Split a document into overlapping chunks.
    overlap=50: consecutive chunks share 50 chars.
    This prevents cutting a sentence in half at a boundary.
    """
    chunks = []
    start = 0
    while start < len(text):
        end = start + chunk_size
        chunk = text[start:end]
        chunks.append({
            "content": chunk,
            "source": source,
            "chunk_id": len(chunks)
        })
        start = end - overlap
        if start >= len(text):
            break
    return chunks

all_chunks = []
for doc in medical_documents:
    chunks = chunk_document(doc["content"], doc["source"])
    all_chunks.extend(chunks)

print(f"Total chunks created: {len(all_chunks)}")
print(f"Average chunk size: {sum(len(c['content']) for c in all_chunks) // len(all_chunks)} chars")
print(f"\nSample chunk 1:")
print(f"  Source: {all_chunks[0]['source']}")
print(f"  Content: {all_chunks[0]['content'][:120]}...")
print(f"\nSample chunk 5:")
print(f"  Source: {all_chunks[4]['source']}")
print(f"  Content: {all_chunks[4]['content'][:120]}...")

# ------------------------------------------------------------
# PART B: Load embedding model
# ------------------------------------------------------------
# all-MiniLM-L6-v2 creates 384-dimensional vectors.
# Fast, small, excellent for semantic search.
# Used in production by many RAG systems.
# OpenAI offers text-embedding-3-large (3072 dims) for
# higher quality at higher cost. We get good quality for free.

print("\nLoading embedding model...")
embedder = SentenceTransformer("all-MiniLM-L6-v2")
print(f"Embedding model loaded")
print(f"Output dimensions: {embedder.get_sentence_embedding_dimension()}")

# ------------------------------------------------------------
# PART C: Create embeddings for all chunks
# ------------------------------------------------------------
# This converts every chunk from text into a 384-dim vector.
# Similar medical concepts will have similar vectors.
# "heart attack" and "myocardial infarction" → similar vectors
# "heart attack" and "basketball game" → very different vectors

print("\nCreating embeddings for all chunks...")
texts = [c["content"] for c in all_chunks]
embeddings = embedder.encode(
    texts,
    show_progress_bar=True,
    batch_size=32,
    convert_to_numpy=True
)

print(f"Embeddings shape: {embeddings.shape}")
print(f"Each chunk is now a vector of {embeddings.shape[1]} numbers")

# ------------------------------------------------------------
# PART D: Build FAISS index
# ------------------------------------------------------------
# FAISS (Facebook AI Similarity Search) finds the most
# similar vectors to a query vector extremely fast.
# Used by Facebook, Google, Spotify for recommendation.
# In healthcare: Epic uses similar tech for patient matching.
#
# IndexFlatIP = exact search with inner product (dot product)
# When vectors are normalized: dot product = cosine similarity
# Cosine similarity = how similar are two vectors in direction

faiss.normalize_L2(embeddings)
embedding_dim = embeddings.shape[1]
index = faiss.IndexFlatIP(embedding_dim)
index.add(embeddings.astype(np.float32))

print(f"\nFAISS index built!")
print(f"Vectors indexed: {index.ntotal}")
print(f"Vector dimensions: {embedding_dim}")

# Save index and chunks to disk
faiss.write_index(index, "/kaggle/working/medical_knowledge.faiss")
with open("/kaggle/working/medical_chunks.json", "w") as f:
    json.dump(all_chunks, f)

print(f"\nSaved to disk:")
print(f"  /kaggle/working/medical_knowledge.faiss")
print(f"  /kaggle/working/medical_chunks.json")
print(f"\nRAG knowledge base is ready!")


