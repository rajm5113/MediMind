# Load saved index and chunks
index = faiss.read_index("/kaggle/working/medical_knowledge.faiss")
with open("/kaggle/working/medical_chunks.json") as f:
    all_chunks = json.load(f)

print(f"Loaded FAISS index: {index.ntotal} vectors")
print(f"Loaded chunks: {len(all_chunks)}")

# ------------------------------------------------------------
# PART A: Retrieval function
# ------------------------------------------------------------
def retrieve_context(query, top_k=3):
    query_embedding = embedder.encode([query], convert_to_numpy=True)
    faiss.normalize_L2(query_embedding)
    similarities, indices = index.search(
        query_embedding.astype(np.float32), top_k
    )
    results = []
    for sim, idx in zip(similarities[0], indices[0]):
        if idx != -1:
            results.append({
                "content": all_chunks[idx]["content"],
                "source": all_chunks[idx]["source"],
                "similarity": float(sim)
            })
    return results

# ------------------------------------------------------------
# PART B: Test retrieval quality
# ------------------------------------------------------------
test_queries = [
    "Why is ciprofloxacin dangerous in pregnancy?",
    "What should I do if I have chest pain?",
    "How does metformin work?",
    "Iron poisoning in child",
]

print("\n" + "="*60)
print("RETRIEVAL TEST")
print("="*60)

for query in test_queries:
    print(f"\nQuery: '{query}'")
    results = retrieve_context(query, top_k=2)
    for i, r in enumerate(results):
        print(f"  Result {i+1} [sim={r['similarity']:.3f}]: {r['source']}")
        print(f"    {r['content'][:100]}...")

# ------------------------------------------------------------
# PART C: Full RAG answer function — FIXED prompt trigger
# ------------------------------------------------------------
def ask_medimind_rag(question, top_k=3):
    context_results = retrieve_context(question, top_k=top_k)

    if not context_results:
        context_text = "No relevant guidelines found."
        sources = []
    else:
        context_pieces = []
        sources = []
        for r in context_results:
            context_pieces.append(
                f"[Source: {r['source']}]\n{r['content']}"
            )
            sources.append(r['source'])
        context_text = "\n\n".join(context_pieces)

    # FIXED: Using ### Clinical Response: instead of ### Answer:
    # This matches the new training format and breaks the MCQ association.
    # The model was trained with ### Clinical Response: as the answer trigger.
    # Using ### Answer: would still activate the MCQ pattern from old training.
    prompt = f"""### System:
You are MediMind, an expert medical AI assistant.
Answer the question using ONLY the medical guidelines provided below.
Be specific and cite which guideline your answer comes from.
Always recommend consulting a licensed physician.

### Medical Guidelines:
{context_text}

### Question:
{question}

### Clinical Response:
"""

    inputs = tokenizer(
        prompt,
        return_tensors="pt",
        truncation=True,
        max_length=1024
    ).to(model.device)
    # FIXED: using model.device instead of dpo_trainer.model.device
    # After DPO training completes, the aligned model is stored in
    # dpo_trainer.model — but we reference it as model for clarity.
    # Change this to dpo_trainer.model if that variable is available.

    with torch.no_grad():
        outputs = model.generate(
            **inputs,
            max_new_tokens=200,
            temperature=0.2,
            top_p=0.9,
            do_sample=True,
            pad_token_id=tokenizer.eos_token_id,
        )

    full = tokenizer.decode(outputs[0], skip_special_tokens=True)

    # FIXED: split on new trigger token
    if "### Clinical Response:" in full:
        answer = full.split("### Clinical Response:")[-1].strip()
    else:
        answer = full.split("### Answer:")[-1].strip()

    return {
        "answer": answer,
        "sources": list(set(sources)),
        "num_chunks_retrieved": len(context_results)
    }

# ------------------------------------------------------------
# PART D: Test full RAG pipeline
# ------------------------------------------------------------
print("\n" + "="*60)
print("FULL RAG PIPELINE TEST")
print("="*60)

rag_questions = [
    "Why is Ciprofloxacin avoided in pregnant patients with UTI?",
    "I have chest pain radiating to my left arm. What should I do?",
    "What is the HbA1c target for Type 2 diabetes?",
    "My child swallowed iron tablets and seems fine. Should I worry?"
]

for q in rag_questions:
    print(f"\n{'='*60}")
    print(f"Q: {q}")
    print(f"{'='*60}")
    result = ask_medimind_rag(q)
    print(f"Answer:\n{result['answer']}")
    print(f"\nSources used: {result['sources']}")
    print(f"Chunks retrieved: {result['num_chunks_retrieved']}")
