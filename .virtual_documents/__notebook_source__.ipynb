import os
import zipfile
from IPython.display import FileLink

def zip_dir(directory = os.curdir, file_name = 'my_project_files.zip'):
    """
    Zips all files in the specified directory and creates a download link.
    """
    os.chdir('/kaggle/working')
    zip_ref = zipfile.ZipFile(file_name, mode='w')
    for folder, _, files in os.walk(directory):
        for file in files:
            # Avoid zipping the zip file itself
            if file == file_name:
                continue
            path = os.path.join(folder, file)
            zip_ref.write(path, arcname=os.path.relpath(path, directory))
    zip_ref.close()
    return FileLink(file_name)

zip_dir()



