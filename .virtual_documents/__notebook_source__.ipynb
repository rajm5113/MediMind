# we build a custom LangChain-compatible retriever using
# the FAISS index we already built in Phase 3.
# This inherits from BaseRetriever — the standard LangChain
# interface that ConversationalRetrievalChain expects.

class MedicalFAISSRetriever(BaseRetriever):
    """
    Custom LangChain retriever wrapping our Phase 3 FAISS index.
    Implements the BaseRetriever interface so it works with
    any LangChain chain that expects a retriever object.
    This is the same pattern used in production RAG systems
    when using custom vector stores.
    """

    class Config:
        arbitrary_types_allowed = True

    def _get_relevant_documents(self, query: str) -> List[Document]:
        # Embed the query
        query_embedding = embeddings_model.embed_query(query)
        query_vec = np.array([query_embedding], dtype=np.float32)
        faiss.normalize_L2(query_vec)

        # Search FAISS
        similarities, indices = faiss_index.search(query_vec, 3)

        # Return LangChain Document objects
        docs = []
        for sim, idx in zip(similarities[0], indices[0]):
            if idx != -1 and sim > 0.3:
                chunk = faiss_chunks[idx]
                docs.append(Document(
                    page_content=chunk["content"],
                    metadata={
                        "source": chunk["source"],
                        "similarity": float(sim)
                    }
                ))
        return docs

    async def _aget_relevant_documents(self, query: str) -> List[Document]:
        return self._get_relevant_documents(query)

