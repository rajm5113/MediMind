import torch
import warnings
warnings.filterwarnings('ignore')
from transformers import AutoModelForCausalLM, AutoTokenizer
from peft import LoraConfig, get_peft_model, prepare_model_for_kbit_training
from trl import SFTTrainer, SFTConfig
from datasets import load_dataset

print(f"PyTorch: {torch.__version__}")
print(f"GPU 0: {torch.cuda.get_device_name(0)}")
print(f"GPU 1: {torch.cuda.get_device_name(1)}")
print("All imports OK")


# ============================================================
# CELL 4: Dataset with FIXED format
# ============================================================
# KEY FIX: Answer format changed from
#   "The correct answer is E: Nitrofurantoin."
# to
#   "According to clinical guidelines, the answer is E: Nitrofurantoin."
#
# This breaks the MCQ association that caused the model
# to respond with "The correct answer is A" to everything.
# Small change, big behavioral difference.

from datasets import load_dataset

dataset = load_dataset("medalpaca/medical_meadow_medqa", split="train")
dataset = dataset.select(range(2000))

def format_medical_prompt(example):
    raw_answer = example['output'].strip()
    # FIXED format — no more "The correct answer is"
    expanded_answer = (
        f"According to clinical guidelines, the answer is {raw_answer}. "
        f"This choice is supported by evidence-based medicine. "
        f"Patient-specific factors should always be considered, "
        f"and a licensed physician should be consulted for treatment decisions."
    )
    text = f"""### System:
You are MediMind, an expert medical AI assistant. Answer medical questions in complete sentences with clear clinical reasoning. Always recommend consulting a licensed physician.

### Question:
{example['input']}

### Clinical Response:
{expanded_answer}"""
    return {"text": text}

dataset = dataset.map(format_medical_prompt)
print(f"Dataset ready: {len(dataset)} examples")
print(f"\nSample answer format:")
# Show just the answer part
sample = dataset[0]['text']
answer_part = sample.split("### Clinical Response:")[-1].strip()
print(answer_part[:200])


# ============================================================
# CELL 5: Load model in bf16 — NO quantization
# ============================================================
# KEY FIX: Load in bf16 NOT 4-bit quantization
#
# Last run used BitsAndBytesConfig but fell back to float32
# causing 352 minute training time.
#
# bf16 approach:
#   Phi-2 in bf16 = 5.4GB per GPU
#   We have 15.6GB per GPU, 31.2GB total
#   Fits easily, no quantization needed
#   bf16 training = same speed as fp16, no scaler issues
#   Result: ~70-90 min training instead of 352 min

print("Loading tokenizer...")
tokenizer = AutoTokenizer.from_pretrained(
    "microsoft/phi-2",
    trust_remote_code=True
)
tokenizer.pad_token = tokenizer.eos_token
tokenizer.padding_side = "right"
print("Tokenizer loaded")

for i in range(torch.cuda.device_count()):
    free = torch.cuda.mem_get_info(i)[0] / 1e9
    print(f"GPU {i} free before load: {free:.1f}GB")

print("\nLoading Phi-2 in bf16...")
model = AutoModelForCausalLM.from_pretrained(
    "microsoft/phi-2",
    torch_dtype=torch.bfloat16,
    device_map="auto",
    trust_remote_code=True,
)
print(f"Model loaded in: {next(model.parameters()).dtype}")

for i in range(torch.cuda.device_count()):
    free = torch.cuda.mem_get_info(i)[0] / 1e9
    used = 15.64 - free
    print(f"GPU {i}: {used:.1f}GB used, {free:.1f}GB free")


# ============================================================
# CELL 6: Prepare + LoRA
# ============================================================
from peft import LoraConfig, get_peft_model

lora_config = LoraConfig(
    r=16,
    lora_alpha=32,
    target_modules=["q_proj", "k_proj", "v_proj", "dense"],
    lora_dropout=0.1,
    bias="none",
    task_type="CAUSAL_LM",
)

model = get_peft_model(model, lora_config)
model.config.use_cache = False

trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)
total = sum(p.numel() for p in model.parameters())
print(f"LoRA injected")
print(f"Trainable: {trainable:,} ({100*trainable/total:.2f}%)")
print(f"Model dtype: {next(model.parameters()).dtype}")


# ============================================================
# CELL 7: Train — bf16, should take ~70-90 minutes
# ============================================================
from trl import SFTTrainer, SFTConfig
import time

sft_config = SFTConfig(
    output_dir="./medimind-phi2-lora",
    num_train_epochs=3,
    per_device_train_batch_size=2,
    gradient_accumulation_steps=4,
    learning_rate=2e-4,
    lr_scheduler_type="cosine",
    warmup_steps=11,
    bf16=True,
    fp16=False,
    logging_steps=10,
    save_strategy="epoch",
    optim="paged_adamw_32bit",
    report_to="none",
    push_to_hub=False,
    dataloader_pin_memory=False,
    ddp_find_unused_parameters=False,
    max_length=512,
    dataset_text_field="text",
    packing=False,
    remove_unused_columns=True,
)

trainer = SFTTrainer(
    model=model,
    train_dataset=dataset,
    args=sft_config,
    processing_class=tokenizer,
)

trainable = sum(p.numel() for p in trainer.model.parameters() if p.requires_grad)
print(f"Trainer ready. Trainable params: {trainable:,}")
for i in range(torch.cuda.device_count()):
    free = torch.cuda.mem_get_info(i)[0] / 1e9
    used = 15.64 - free
    print(f"GPU {i}: {used:.1f}GB used, {free:.1f}GB free")

print("\nStarting training...")
print("With bf16 + dual T4 target: 70-90 minutes")
print("Loss should start ~2.0 and end ~0.9\n")

start = time.time()
trainer.train()
end = time.time()

print(f"\nTRAINING COMPLETE! Time: {(end-start)/60:.1f} minutes")


