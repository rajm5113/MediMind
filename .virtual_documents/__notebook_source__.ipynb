    faiss_chunks = json.load(f)

print(f"Loaded {faiss_index.ntotal} vectors, {len(faiss_chunks)} chunks")

retriever = MedicalFAISSRetriever()
print("Custom FAISS retriever ready")

# ------------------------------------------------------------
# PART D: Prompt template
# ------------------------------------------------------------
MEDICAL_PROMPT = PromptTemplate(
    input_variables=["context", "chat_history", "question"],
    template="""### System:
You are MediMind, an expert medical AI assistant.
Answer using the medical guidelines below. Be specific and cite sources.
For emergencies, direct to 911 or Poison Control immediately.
Always recommend consulting a licensed physician.

### Medical Guidelines:
{context}

### Conversation History:
{chat_history}

### Question:
{question}

### Clinical Response:
"""
)

# ------------------------------------------------------------
# PART E: Conversation memory
# ------------------------------------------------------------
memory = ConversationBufferWindowMemory(
    memory_key="chat_history",
    k=5,
    return_messages=True,
    output_key="answer"
)
print("Conversation memory initialized")

# ------------------------------------------------------------
# PART F: Build the full chain
# ------------------------------------------------------------
medimind_chain = ConversationalRetrievalChain.from_llm(
    llm=llm,
    retriever=retriever,
    memory=memory,
    combine_docs_chain_kwargs={"prompt": MEDICAL_PROMPT},
    return_source_documents=True,
    verbose=False,
)

print("\nMediMind LangChain chain ready!")
print("Pipeline: Query -> Memory -> FAISS -> MediMind -> Response")





