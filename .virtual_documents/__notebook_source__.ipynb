import gradio as gr
import torch
import numpy as np
import faiss
import json

# ------------------------------------------------------------
# Core inference function
# ------------------------------------------------------------
def medimind_respond(message, history):
    """
    Main function called by Gradio on every user message.
    Runs the full RAG pipeline:
    1. Retrieve relevant medical guidelines from FAISS
    2. Build grounded prompt with context
    3. Generate response using MediMind
    4. Return response with citations
    """
    if not message.strip():
        return history, ""

    # Step 1: Retrieve relevant context
    try:
        query_embedding = embeddings_model.embed_query(message)
        query_vec = np.array([query_embedding], dtype=np.float32)
        faiss.normalize_L2(query_vec)
        similarities, indices = faiss_index.search(query_vec, 3)

        context_pieces = []
        sources = []
        for sim, idx in zip(similarities[0], indices[0]):
            if idx != -1 and sim > 0.25:
                chunk = faiss_chunks[idx]
                context_pieces.append(
                    f"[{chunk['source']}]: {chunk['content']}"
                )
                sources.append(chunk['source'])

        context_text = "\n\n".join(context_pieces) if context_pieces else "No specific guidelines found."
        unique_sources = list(set(sources))

    except Exception as e:
        context_text = "No specific guidelines found."
        unique_sources = []

    # Step 2: Build conversation history string
    history_text = ""
    for turn in history[-3:]:
        if isinstance(turn, dict):
            role = turn.get("role", "")
            content = turn.get("content", "")
            if role == "user":
                history_text += f"User: {content}\n"
            elif role == "assistant":
                history_text += f"Assistant: {content[:200]}\n"

    # Step 3: Build prompt
    prompt = f"""### System:
You are MediMind, an expert medical AI assistant.
Answer using the medical guidelines provided. Be specific and direct.
For any emergency symptoms like chest pain, difficulty breathing, or overdose,
immediately direct the user to call 911 or Poison Control 1-800-222-1222.
Always recommend consulting a licensed physician.

### Medical Guidelines:
{context_text}

### Recent Conversation:
{history_text}

### Question:
{message}

### Clinical Response:
"""

    # Step 4: Generate response
    inputs = tokenizer(
        prompt,
        return_tensors="pt",
        truncation=True,
        max_length=900
    ).to(model.device)

    with torch.no_grad():
        outputs = model.generate(
            **inputs,
            max_new_tokens=150,
            temperature=0.1,
            top_p=0.9,
            do_sample=True,
            repetition_penalty=1.3,
            pad_token_id=tokenizer.eos_token_id,
            eos_token_id=tokenizer.eos_token_id,
        )

    full = tokenizer.decode(outputs[0], skip_special_tokens=True)

    # Extract only the answer
    if "### Clinical Response:" in full:
        answer = full.split("### Clinical Response:")[-1].strip()
    else:
        answer = full.split("### Question:")[-1].strip()

    # Clean up repetitive sentences
    sentences = answer.split(". ")
    seen = set()
    clean_sentences = []
    for s in sentences:
        s_clean = s.strip()
        if s_clean and s_clean not in seen:
            seen.add(s_clean)
            clean_sentences.append(s_clean)
        if len(clean_sentences) >= 5:
            break
    answer = ". ".join(clean_sentences)
    if answer and not answer.endswith("."):
        answer += "."

    # Add sources
    if unique_sources:
        answer += f"\n\n**Sources:** {', '.join(unique_sources)}"

    # Add disclaimer
    answer += "\n\n*Always consult a licensed physician for diagnosis and treatment.*"

    # Update history
    history.append({"role": "user", "content": message})
    history.append({"role": "assistant", "content": answer})

    return history, ""


